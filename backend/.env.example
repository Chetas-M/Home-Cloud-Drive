# Environment Configuration
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME
DATABASE_URL=sqlite+aiosqlite:///./data/homecloud.db
STORAGE_PATH=./storage
MAX_STORAGE_BYTES=107374182400
ACCESS_TOKEN_EXPIRE_MINUTES=1440
PASSWORD_RESET_EXPIRE_MINUTES=30
# Allow new user signups (default: false for security)
ALLOW_REGISTRATION=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Home Cloud
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=15
# Optional explicit frontend URL to use in reset emails, e.g. https://cloud.example.com/
PASSWORD_RESET_URL=
